<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:collections="using:Avalonia.Collections">
        <!-- ───── DataGrid: общие настройки ───── -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{DynamicResource surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource main_text}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="RowBackground" Value="{DynamicResource surface}"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- ───── Заголовки колонок ───── -->
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource secondary_background}"/>
        <Setter Property="Foreground" Value="{DynamicResource main_text}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12 8 0 8 "/>
        <Setter Property="AreSeparatorsVisible" Value="False"/>
        <Setter Property="BorderThickness" Value=" 0 0 0 1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource border}"/>
    </Style>
        
    <Style Selector="DataGridColumnHeader:pointerover">
        <Setter Property="Background" Value="{DynamicResource secondary_background}"/>
    </Style>
        
    <Style Selector="DataGridColumnHeader:pressed">
        <Setter Property="Background" Value="{DynamicResource secondary_background}"/>
    </Style>
    <!-- Вертикальный разделитель между заголовками колонок -->
    <Style Selector="DataGridColumnHeader /template/ Rectangle#PART_VerticalSeparator">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Граница внутри шаблона заголовка колонки -->
    <Style Selector="DataGridColumnHeader /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ───── Шаблон самого DataGrid ───── -->

    <!-- Горизонтальные линии сетки внутри DataGrid -->
    <Style Selector="DataGrid /template/ Line">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Разделитель между областью заголовков и строками -->
    <Style Selector="DataGrid /template/ Rectangle#PART_ColumnHeadersAndRowsSeparator">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Внешние границы контейнеров внутри шаблона DataGrid -->
    <Style Selector="DataGrid /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ───── Заголовок строки (левый столбец-маркер) ───── -->

    <!-- Граница внутри шаблона заголовка строки -->
    <Style Selector="DataGridRowHeader /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Скрываем столбец заголовка строки полностью -->
    <Style Selector="DataGridRowHeader">
        <Setter Property="Width" Value="0"/>
    </Style>

    <!-- ───── Строки ───── -->
    <Style Selector="DataGridRow">
        <Setter Property="BorderThickness" Value=" 0 1 0 0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource border}"/>
    </Style>
    
    <Style Selector="DataGridRow:nth-last-child(1)">
        <Setter Property="BorderThickness" Value="0 1 0 1"/>
    </Style>
    <Style Selector="DataGridRow:nth-child(1)">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Фон строки в обычном состоянии -->
    <Style Selector="DataGridRow /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource surface}"/>
    </Style>

    <!-- Фон строки при наведении курсора -->
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource surface}"/>
    </Style>

    <!-- Фон выбранной строки -->
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource surface}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Фон выбранной строки при наведении курсора -->
    <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource surface}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Цвет текста выбранной строки -->
    <Style Selector="DataGridRow:selected">
        <Setter Property="Foreground" Value="{DynamicResource main_text}"/>
    </Style>

    <!-- Убираем границы вокруг строки -->
    <Style Selector="DataGridRow /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ───── Ячейки ───── -->
    <Style Selector="DataGridCell">
        <Setter Property="Padding" Value="0 6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>

    <!-- Убираем обводку активной ячейки -->
    <Style Selector="DataGridCell:current">
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Убираем обводку выбранной ячейки -->
    <Style Selector="DataGridCell:selected">
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Убираем визуальный индикатор фокуса активной ячейки -->
    <Style Selector="DataGridCell:current /template/ Grid#FocusVisual">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Убираем границы внутри шаблона ячейки -->
    <Style Selector="DataGridCell /template/ Border">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</Styles>