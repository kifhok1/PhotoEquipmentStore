<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Panel Height="800" Width="1280" Background="{DynamicResource main_background}">
            <Panel Classes="Popup">
                <!-- Рамка -->
                <Border Background="{DynamicResource secondary_background}"
                        Opacity="0.9"/>
                <!-- Контент -->
                <Border Height="200" Width="400" 
                        Background="{DynamicResource main_background}"
                        BorderThickness="2"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource border}">
                    
                </Border>
            </Panel>
        </Panel>
    </Design.PreviewWith>

    <Style Selector="Panel.Popup">
        <Style.Animations>
            <Animation Duration="0:0:0.25" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>
