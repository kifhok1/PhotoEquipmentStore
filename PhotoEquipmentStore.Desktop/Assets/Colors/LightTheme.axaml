<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="primary" Color="#4E6EF5"/>
    <SolidColorBrush x:Key="accent" Color="#F5A623"/>
    <SolidColorBrush x:Key="success" Color="#2ECC71"/>
    <SolidColorBrush x:Key="warning" Color="#F39C12"/>
    <SolidColorBrush x:Key="error" Color="#E74C3C"/>
    <SolidColorBrush x:Key="info" Color="#3498DB"/>
    
    <SolidColorBrush x:Key="main_background" Color="#F5F7FB"/>
    <SolidColorBrush x:Key="secondary_background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="raised" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="main_text" Color="#1A1F36"/>
    <SolidColorBrush x:Key="secondary_text" Color="#4A5073"/>
    <SolidColorBrush x:Key="muted_text" Color="#9BA3BF"/>
    <SolidColorBrush x:Key="border" Color="#E2E5EF"/>
</ResourceDictionary>
