<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PhotoEquipmentStore.ViewModels.Pages.Manager"
             xmlns:b="clr-namespace:PhotoEquipmentStore.Behaviors"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             mc:Ignorable="d" d:DesignWidth="1030" d:DesignHeight="800"
             xmlns:conv="clr-namespace:PhotoEquipmentStore.Converters"
             x:Class="PhotoEquipmentStore.Views.Pages.Manager.ReportsView"
             x:DataType="vm:ReportsViewModel">

    <i:Interaction.Behaviors>
        <b:StorageProviderInjectorBehavior/>
        <b:InitializeDatesOnAttachedBehavior/>
    </i:Interaction.Behaviors>

    <Border Background="{DynamicResource main_background}" Padding="10">
        <Grid ColumnDefinitions="* * *"
              RowDefinitions="* * * * *"
              RowSpacing="10"
              ColumnSpacing="8">

            <!-- ── Заказов сегодня ── -->
            <Border Grid.Row="0" Grid.Column="0"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource primary}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource primary}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Order}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Заказов сегодня</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Оформлено заказов в этот день
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding OrdersToday}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Товаров сегодня ── -->
            <Border Grid.Row="0" Grid.Column="1"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource success}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource success}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Product}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Товаров сегодня</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Продано товаров за этот день
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding ItemsToday}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Выручка сегодня ── -->
            <Border Grid.Row="0" Grid.Column="2"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource accent}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource accent}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Price}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Выручка сегодня</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Выручка с проданных товаров сегодня
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding RevenueToday}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Заказов за месяц ── -->
            <Border Grid.Row="1" Grid.Column="0"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource primary}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource primary}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Order}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Заказов за месяц</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Оформлено заказов за этот месяц
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding OrdersMonth}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Товаров за месяц ── -->
            <Border Grid.Row="1" Grid.Column="1"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource success}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource success}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Product}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Товаров за месяц</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Продано товаров за этот месяц
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding ItemsMonth}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Выручка за месяц ── -->
            <Border Grid.Row="1" Grid.Column="2"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource accent}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource accent}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Price}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Выручка за месяц</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Выручка с проданных товаров за месяц
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 20 16 8">
                        <TextBlock Classes="H2" HorizontalAlignment="Center"
                                   Text="{Binding RevenueMonth}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Отчёт по продажам ── -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource accent}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource accent}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Order}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Отчёт по продажам</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Отчёт о количестве оформленных заказов
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 8 16 8">
                        <Grid ColumnDefinitions="Auto *" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    ВРЕМЕННОЙ ПРОМЕЖУТОК
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <CalendarDatePicker Width="250"
                                                        SelectedDate="{Binding SalesDateFrom, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        DisplayDateStart="{Binding SalesMinDate, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        DisplayDateEnd="{Binding SalesDateFromMax, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        Watermark="дд.мм.гггг"/>

                                    <CalendarDatePicker Width="250"
                                                        SelectedDate="{Binding SalesDateTo, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        DisplayDateStart="{Binding SalesDateToMin, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        DisplayDateEnd="{Binding SalesMaxDate, Converter={x:Static conv:DateTimeOffsetToDateTimeConverter.Instance}}"
                                                        Watermark="дд.мм.гггг"/>
                                </StackPanel>
                            </StackPanel>
                            <Panel Grid.Column="1">
                                <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Background="{DynamicResource accent}"
                                        Command="{Binding BuildSalesReportCommand}">
                                    Создать отчёт
                                </Button>
                            </Panel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Остатки на складе ── -->
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource success}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource success}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Stock}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Остаток товаров на складе</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Отчёт о количестве товаров, записанных на складе
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 8 16 8">
                        <Grid ColumnDefinitions="Auto *" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    КАТЕГОРИЯ ТОВАРА
                                </TextBlock>
                                <ComboBox MinWidth="220"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding StockCategories}"
                                          SelectedItem="{Binding SelectedStockCategory}"
                                          DisplayMemberBinding="{Binding Name}"/>
                            </StackPanel>
                            <Panel Grid.Column="1">
                                <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Background="{DynamicResource success}"
                                        Command="{Binding BuildStockReportCommand}">
                                    Создать отчёт
                                </Button>
                            </Panel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Популярные товары ── -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                    BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                    CornerRadius="8" Background="{DynamicResource surface}">
                <StackPanel>
                    <Border Height="75" BorderBrush="{DynamicResource border}"
                            BorderThickness="0 0 0 2" Padding="16 0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Panel>
                                <Border Height="40" Width="40" Background="{DynamicResource info}"
                                        Opacity="0.25" CornerRadius="10"/>
                                <Path Stroke="{DynamicResource info}" StrokeThickness="2"
                                      StrokeJoin="Round" StrokeLineCap="Round"
                                      Margin="-3 -2 0 0" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Data="{DynamicResource Product}"/>
                            </Panel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>Популярность товаров</TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    Товары, отсортированные по частоте покупок
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Padding="16 8 16 8">
                        <Grid ColumnDefinitions="Auto Auto *" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    КАТЕГОРИЯ ТОВАРА
                                </TextBlock>
                                <ComboBox MinWidth="220"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding PopularityCategories}"
                                          SelectedItem="{Binding SelectedPopularityCategory}"
                                          DisplayMemberBinding="{Binding Name}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                    СОРТИРОВКА
                                </TextBlock>
                                <ComboBox MinWidth="260"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding PopularityTypes}"
                                          SelectedItem="{Binding SelectedPopularityType}"/>
                            </StackPanel>
                            <Panel Grid.Column="2">
                                <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Background="{DynamicResource info}"
                                        Command="{Binding BuildPopularityReportCommand}">
                                    Создать отчёт
                                </Button>
                            </Panel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>