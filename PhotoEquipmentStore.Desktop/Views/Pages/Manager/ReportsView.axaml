<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1030" d:DesignHeight="800"
             x:Class="PhotoEquipmentStore.Views.Pages.Manager.ReportsView">
                <Border Background="{DynamicResource main_background}"
                        Padding="10">
                   <Grid ColumnDefinitions="* * *"
                         RowDefinitions="* * * * *"
                         RowSpacing="10"
                         ColumnSpacing="8">
                       <Border Grid.Row="0" Grid.Column="0"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource primary}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource primary}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Order}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Заказов сегодня
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Оформленно заказов в этот день
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">3 за этот день</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       <Border Grid.Row="0" Grid.Column="1"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource success}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource success}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Product}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Товаров сегодня
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Продано товаров за этот день
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">5 за этот день</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       <Border Grid.Row="0" Grid.Column="2"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource accent}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource accent}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Price}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Выручка сегодня
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Выручка с проданных товаров сегодня
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">234600₽ сегодня</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       <Border Grid.Row="1" Grid.Column="0"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource primary}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource primary}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Order}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Заказов за месяц
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Оформленно заказов за этот месяц
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">28 за этот месяц</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       <Border Grid.Row="1" Grid.Column="1"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource success}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource success}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Product}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Товаров за месяц
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Продано товаров за этот месяц
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">56 за этот месяц</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       <Border Grid.Row="1" Grid.Column="2"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource accent}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource accent}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Price}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Выручка за месяц
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Выручка с проданных товаров за месяц
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 20 16 8">
                                            <TextBlock Classes="H2" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">3129000₽ за месяц</TextBlock>
                                        </Border>
                                </StackPanel>
                       </Border>
                       
                       <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource accent}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource accent}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Order}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Отчёт по продажам
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Отчёт количестве оформленных заказов
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 8 16 8">
                                                <Grid ColumnDefinitions="Auto *"
                                                            ColumnSpacing="8">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                            ВРЕМЕННОЙ ПРОМЕЖУТОК
                                                        </TextBlock>
                                                        <ComboBox Width="200" PlaceholderText="За всё время"/>
                                                    </StackPanel>
                                                    <Panel Grid.Column="1" >
                                                         <Button HorizontalAlignment="Right"
                                                                 VerticalAlignment="Bottom"
                                                                 Background="{DynamicResource accent}">
                                                             Создать отчёт
                                                         </Button>
                                                    </Panel>
                                                </Grid>
                                        </Border>
                                </StackPanel>
                       </Border>
                       
                       <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                           <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource success}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource success}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Stock}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Остаток товаров на складе
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Отчёт о количестве товаров которые записаны на складе
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 8 16 8">
                                                <Grid ColumnDefinitions="Auto *"
                                                            ColumnSpacing="8">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                            КАТЕГОРИЯ ТОВАРА
                                                        </TextBlock>
                                                        <ComboBox Width="200" PlaceholderText="Все категории"/>
                                                    </StackPanel>
                                                    <Panel Grid.Column="1" >
                                                         <Button HorizontalAlignment="Right"
                                                                 VerticalAlignment="Bottom"
                                                                 Background="{DynamicResource success}">
                                                             Создать отчёт
                                                         </Button>
                                                    </Panel>
                                                </Grid>
                                        </Border>
                                </StackPanel>
                       </Border>
                       
                       <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                               BorderThickness="1.5"
                               BorderBrush="{DynamicResource border}"
                               CornerRadius="8"
                               Background="{DynamicResource surface}">
                                <StackPanel>
                                        <Border Height="75"
                                                BorderBrush="{DynamicResource border}"
                                                BorderThickness="0 0 0 2"
                                                Padding="16 0"
                                                ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12" VerticalAlignment="Center">
                                                <Panel>
                                                    <Border Height="40" Width="40"
                                                            Background="{DynamicResource info}"
                                                            Opacity="0.25" CornerRadius="10"/>
                                                    <Path Stroke="{DynamicResource info}"
                                                          StrokeThickness="2" StrokeJoin="Round" StrokeLineCap="Round"
                                                          Margin="-3 -2 0 0"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="{DynamicResource Product}"/>
                                                </Panel>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock>
                                                        Самые популярные товары
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                        Товары которые которые покупают чаще всего
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="16 8 16 8">
                                                <Grid ColumnDefinitions="Auto Auto *"
                                                            ColumnSpacing="8">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                            КАТЕГОРИЯ ТОВАРА
                                                        </TextBlock>
                                                        <ComboBox Width="200" PlaceholderText="Все категории"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource secondary_text}">
                                                            КОЛИЧЕСТВО ТОВАРОВ
                                                        </TextBlock>
                                                        <ComboBox Width="250" PlaceholderText="Все товары"/>
                                                    </StackPanel>
                                                    <Panel Grid.Column="2" >
                                                         <Button HorizontalAlignment="Right"
                                                                 VerticalAlignment="Bottom"
                                                                 Background="{DynamicResource info}">
                                                                 Создать отчёт
                                                         </Button>
                                                    </Panel>
                                                </Grid>
                                        </Border>
                                </StackPanel>
                       </Border>
                   </Grid>
                </Border>
</UserControl>
