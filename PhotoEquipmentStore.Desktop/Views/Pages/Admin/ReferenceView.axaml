<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1030" d:DesignHeight="800"
             xmlns:viewModels="clr-namespace:PhotoEquipmentStore.ViewModels.Pages.Admin"
             x:Class="PhotoEquipmentStore.Views.Pages.Admin.ReferenceView"
             x:DataType="viewModels:ReferenceViewModel">
    <Design.DataContext>
        <viewModels:ReferenceViewModel/>
    </Design.DataContext>
    <Border Background="{DynamicResource main_background}" Padding="20">
                    <Grid RowSpacing="15" RowDefinitions="Auto *">
                        <Border Grid.Row="0" BorderThickness="1.5" BorderBrush="{DynamicResource border}"
                                Padding="10" Background="{DynamicResource surface}"
                                CornerRadius="10">
                            <Grid ColumnDefinitions="* Auto">
                                    <Border Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            BorderBrush="{DynamicResource border}"
                                            BorderThickness="1.5"
                                            CornerRadius="6"
                                            Background="{DynamicResource secondary_background}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="Роли" Classes="SelectPage" IsChecked="{Binding IsSelectedRole}"/>
                                            <RadioButton Content="Поставщики" Classes="SelectPage" IsChecked="{Binding IsSelectedSupplier}"/>
                                            <RadioButton Content="Производители" Classes="SelectPage" IsChecked="{Binding IsSelectedManufacture}"/>
                                            <RadioButton Content="Категории" Classes="SelectPage" IsChecked="{Binding IsSelectedCategory}"/>
                                            <RadioButton Content="Статусы заказов" Classes="SelectPage" IsChecked="{Binding IsSelectedStatusOrder}"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Grid.Column="1" IsVisible="{Binding IsCreateDeleteVisible}"
                                            VerticalAlignment="Stretch" 
                                            Command="{Binding AddReferenceCommand}">
                                        Создать
                                    </Button>
                            </Grid>
                        </Border>
                        
                        <Border Grid.Row="1" BorderBrush="{DynamicResource border}"
                                            CornerRadius="10"
                                            BorderThickness="1.5"
                                            ClipToBounds="True">
                                <Border ClipToBounds="True"
                                        CornerRadius="10"
                                        BorderThickness="0"
                                        Background="{DynamicResource secondary_background}"
                                        BorderBrush="{DynamicResource border}">
                                    <Grid RowDefinitions="* Auto" RowSpacing="10">
                                        <DataGrid IsReadOnly="True"
                                                  AutoGenerateColumns="False"
                                                  ItemsSource="{Binding CurrentReferences}"
                                                  CanUserSortColumns="False"
                                                  BorderBrush="{DynamicResource border}"
                                                  BorderThickness="0 0 0 1">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                    Header="Наименование"
                                                    Binding="{Binding Title}"
                                                    Width="*"/>
                                                <DataGridTemplateColumn Header="Количетво" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Label Classes="ShowFile" 
                                                                   Margin="15 0"
                                                                   Padding="10 4"
                                                                   HorizontalAlignment="Left"
                                                                   Content="{Binding CountShow}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                
                                                <DataGridTemplateColumn Header="Действия">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="18" Margin="18 0">

                                                                <!-- Редактировать -->
                                                                <Button Classes="Ghost"
                                                                        ToolTip.Tip="Редактировать"
                                                                        Padding="0"
                                                                        ClipToBounds="False"
                                                                        Command="{Binding $parent[UserControl].((viewModels:ReferenceViewModel)DataContext).EditReferenceCommand}"
                                                                        CommandParameter="{Binding}">
                                                                    <Viewbox Width="14" Height="14" ClipToBounds="False">
                                                                        <Path Data="{DynamicResource Edit}"/>
                                                                    </Viewbox>
                                                                </Button>

                                                                <!-- Удалить -->
                                                                <Button Classes="Ghost"
                                                                        ToolTip.Tip="Удалить"
                                                                        Padding="0"
                                                                        ClipToBounds="False"
                                                                        IsVisible="{Binding $parent[UserControl].((viewModels:ReferenceViewModel)DataContext).IsCreateDeleteVisible}"
                                                                        IsEnabled="{Binding IsDeleted}"
                                                                        Command="{Binding $parent[UserControl].((viewModels:ReferenceViewModel)DataContext).DeleteCommand}"
                                                                        CommandParameter="{Binding}">
                                                                    <Viewbox Width="14" Height="14" ClipToBounds="False">
                                                                        <Path Data="{DynamicResource Delete}"/>
                                                                    </Viewbox>
                                                                </Button>

                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Panel Grid.Row="1"
                                               Margin="10 0  10 8">
                                            <TextBlock  Classes="Body"
                                                        HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                        Text="{Binding CountReferences}">
                                            </TextBlock>
                                        </Panel>
                                    </Grid>
                                </Border>
                        </Border>
                    </Grid>
                </Border>
</UserControl>
