<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhotoEquipmentStore.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="PhotoEquipmentStore.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             xmlns:controls="clr-namespace:PhotoEquipmentStore.Controls"
             xmlns:popup="clr-namespace:PhotoEquipmentStore.PopupComponent">
    <!-- Файл: Экран входа: промо-блок слева, форма авторизации/капчи справа, кнопки настроек и выхода. -->
    <!-- Контекст данных для предпросмотра в дизайнере Avalonia -->
    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>
    <Border>
        <Panel>
            <!-- Двухколоночная сетка: левая колонка 640px — промо, правая — форма входа -->
            <Grid ColumnDefinitions="640 *">
            <!-- Фоновое изображение левой панели (привязка ImageLoginForm, полупрозрачное) -->
            <Border Grid.Column="0"
                    Background="{DynamicResource secondary_background}">
                <Image Source="{Binding ImageLoginForm}" Stretch="UniformToFill"
                       Opacity="0.15"/>
            </Border>
            <!-- Текстовый промо-блок: логотип, заголовок и описание системы -->
            <Border Grid.Column="0"
                    Padding="48">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border CornerRadius="10"
                                BorderBrush="{DynamicResource primary}"
                                BorderThickness="3"
                                Height="45"
                                Width="45"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ClipToBounds="True">
                            <Path Classes="Logo"/>
                        </Border>
                        <TextBlock Classes="H1" Foreground="{DynamicResource main_text}"
                                   FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            Магазин фототехники
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Classes="H1"
                               FontSize="36"
                               Margin="0 48 0 0"
                               Foreground="{DynamicResource main_text}">
                        Профессиональная
                    </TextBlock>
                    <TextBlock Classes="H1"
                               FontSize="36"
                               Margin="0 0 0 0"
                               Foreground="{DynamicResource primary}">
                        система управления
                    </TextBlock>
                    <TextBlock Classes="H3"
                               Margin="0 24 0 0"
                               FontWeight="Regular"
                               Foreground="{DynamicResource secondary_text}"
                               TextWrapping="Wrap">
                        Передовая платформа управления инвентарём, <LineBreak/>
                        продажами и клиентами, разработанная <LineBreak/>
                        специально для магазинов фототехники.
                    </TextBlock>
                </StackPanel>
            </Border>
            <Panel Grid.Column="1" Background="{DynamicResource main_background}">
                <!-- Форма входа (видна когда капча скрыта) -->
                <controls:LoginBox
                    IsVisible="{Binding !CapchaVisible}"
                    LoginCommand="{Binding LoginCommand}"
                    LoginText="{Binding LoginText}"
                    PasswordText="{Binding PasswordText}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Error="{Binding ErrorConnection}"/>
                <!-- Блок капчи (виден после неудачной попытки входа) -->
                <controls:CapchaBox
                    IsVisible="{Binding CapchaVisible}"
                    ErrorMessage="{Binding ErrorMessage}"
                    ErrorVisible="{Binding ErrorVisible}"
                    WindowBlocked="{Binding WindowBlocked}"
                    ShowCapchaBlock="{Binding CapchaVisible}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Верхний правый угол: настройки и закрытие приложения -->
                <StackPanel Margin="0 10 10 0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Spacing="10"
                            Orientation="Horizontal">
                    <!-- Кнопка открытия SettingsPopup (ShowSettingsCommand) -->
                    <Button Padding="8" Classes="Secondary"
                            ToolTip.Tip="Открыть настройки"
                            Command="{Binding ShowSettingsCommand}">
                        <Button.Content>
                            <Path Data="{DynamicResource Settings}"/>
                        </Button.Content>
                    </Button>
                    <Button Padding="12"
                            Classes="Destructive"
                            Command="{Binding CloseCommand}"
                            ToolTip.Tip="Выйти">
                        <Button.Content>
                            <Path Data="{DynamicResource Сross}"
                                  Width="10"
                                  Margin="0 0 0 0"
                                  Height="10"/>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Panel>
        </Grid>
        <!-- Модальное окно настроек приложения -->
        <popup:SettingsPopup IsVisible="{Binding SettingsVisible}"
                             CloseCommand="{Binding CloseSettingsCommand}"
                             ImageLoginForm="{Binding ImageLoginForm, Mode=TwoWay}"/>
        </Panel>
    </Border>
</UserControl>
