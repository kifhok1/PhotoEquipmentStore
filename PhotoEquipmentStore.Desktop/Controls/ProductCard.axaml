<!-- Карточка товара для каталога при оформлении заказа.
     Отображает изображение, название, категорию, цену и остаток на складе.
     Клик по карточке вызывает SelectCommand; кнопка «+» — AddToCartCommand. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoEquipmentStore.Controls"
             x:Class="PhotoEquipmentStore.Controls.ProductCard"
             x:DataType="local:ProductCard">

    <!-- Внешняя кнопка делает всю карточку кликабельной.
         Прозрачный фон и рамка скрывают стандартный вид Button,
         визуал полностью задаётся вложенным Border. -->
    <Button Background="Transparent"
            BorderBrush="Transparent"
            Padding="0"
            CornerRadius="12"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Command="{Binding SelectCommand, RelativeSource={RelativeSource AncestorType=local:ProductCard}}"
            CommandParameter="{Binding Product, RelativeSource={RelativeSource AncestorType=local:ProductCard}}">

        <!-- Контейнер карточки: фиксированный размер 175×255, скруглённые углы,
             фон из темы (surface), обрезка содержимого по границам. -->
        <Border Background="{DynamicResource surface}"
                CornerRadius="12"
                ClipToBounds="True"
                Width="175" Height="255">
            <!-- Тень карточки: лёгкая в обычном состоянии, усиленная при наведении (pointerover). -->
            <Border.Styles>
                <Style Selector="Border">
                    <Setter Property="BoxShadow" Value="0 2 8 0 #12000000"/>
                </Style>
                <Style Selector="Border:pointerover">
                    <Setter Property="BoxShadow" Value="0 6 20 0 #20000000"/>
                </Style>
            </Border.Styles>

            <!-- Основная сетка: верхняя строка 130px — блок с фото, нижняя — текст и цена.
                 DataContext переключается на Product из родительского ProductCard. -->
            <Grid RowDefinitions="130,*"
                  DataContext="{Binding Product, RelativeSource={RelativeSource AncestorType=local:ProductCard}}">

                <!-- Блок изображения товара на фоне elevated -->
                <Panel Grid.Row="0" Background="{DynamicResource elevated}" ClipToBounds="True">

                    <!-- Фото товара; показывается только если HasImage == true -->
                    <Image Source="{Binding Image}"
                           Stretch="UniformToFill"
                           IsVisible="{Binding HasImage}"/>

                    <!-- Заглушка «Нет фото»: иконка и подпись, когда изображение отсутствует -->
                    <StackPanel IsVisible="{Binding !HasImage}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <Viewbox Width="36" Height="36" ClipToBounds="False" Margin="-9 0 0 0">
                            <Path Data="{DynamicResource NoImage}"
                                  Stroke="{DynamicResource border}"
                                  StrokeThickness="1.5"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Stretch="Uniform"/>
                        </Viewbox>
                        <TextBlock Text="Нет фото"
                                   Foreground="{DynamicResource muted_text}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Бейдж остатка на складе в правом верхнем углу -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,7,7,0"
                            Background="{DynamicResource overlay}"
                            CornerRadius="6"
                            Padding="6,3">
                        <TextBlock Text="{Binding Quantity, StringFormat='{}{0} шт.'}"
                                   Foreground="{DynamicResource white}"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Panel>

                <!-- Нижняя часть карточки: название, категория, цена и кнопка добавления в корзину -->
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Margin="10,9,10,10">

                    <!-- Название товара, до двух строк с переносом -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding Name}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource main_text}"
                               TextWrapping="Wrap" MaxLines="2"/>

                    <!-- Категория товара, приглушённый цвет текста -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding CategoryName}"
                               FontSize="10"
                               Foreground="{DynamicResource muted_text}"
                               Margin="0,3,0,0"/>

                    <!-- Нижняя строка: цена слева, круглая кнопка «+» справа -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                        <!-- Итоговая цена (FinalPrice) с форматированием и символом рубля -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding FinalPrice, StringFormat='{}{0:N0} ₽'}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource accent}"
                                   VerticalAlignment="Center"/>
                        <!-- Кнопка добавления в корзину; CommandParameter — текущий Product -->
                        <Button Grid.Column="1"
                                Width="30" Height="30"
                                CornerRadius="15"
                                Background="{DynamicResource elevated}"
                                Foreground="{DynamicResource primary}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Command="{Binding AddToCartCommand, RelativeSource={RelativeSource AncestorType=local:ProductCard}}"
                                CommandParameter="{Binding}">
                            <Viewbox Width="14" Height="14" ClipToBounds="False" Margin="-5 0 0 -1">
                                <Path Data="{DynamicResource Plus}"
                                      Stroke="{DynamicResource primary}"
                                      StrokeThickness="1.8"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Stretch="Uniform"/>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Button>
</UserControl>
