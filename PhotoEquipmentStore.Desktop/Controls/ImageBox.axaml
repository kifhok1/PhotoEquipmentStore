<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
             x:Class="PhotoEquipmentStore.Controls.ImageBox"
             Background="Transparent">
    <!-- Файл: Drop-zone загрузки изображения 300×300: превью, drag-and-drop, кнопка очистки. -->

    <StackPanel Spacing="6">

        <Grid Height="300" Width="300">

            <Rectangle RadiusX="12" RadiusY="12"
                       Fill="{DynamicResource secondary_background}"
                       Margin="3"/>

            <Border x:Name="ImageLayer"
                    CornerRadius="12"
                    ClipToBounds="True"
                    Margin="3"
                    IsVisible="False">
                <Grid>
                    <Image x:Name="PreviewImage"
                           Stretch="UniformToFill">
                    </Image>

                    <Border VerticalAlignment="Bottom"
                            Background="#CC000000"
                            Padding="10,7">
                        <TextBlock x:Name="FileInfoText"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>

            <Rectangle x:Name="DropBorderRect"
                       RadiusX="14" RadiusY="14"
                       Fill="Transparent"
                       IsHitTestVisible="False"
                       Stroke="{DynamicResource border}"
                       StrokeThickness="3"
                       StrokeDashArray="2, 1"/>

            <StackPanel x:Name="DropContent"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="14"
                        Margin="36,28">

                <Border x:Name="IconCircleBorder"
                        Width="62" Height="62"
                        CornerRadius="31"
                        BorderBrush="{DynamicResource border}"
                        BorderThickness="1.5"
                        Background="{DynamicResource elevated}"
                        HorizontalAlignment="Center">
                    <Viewbox Width="24" Height="24" ClipToBounds="False">
                        <Path x:Name="IconPath"
                              Data="{DynamicResource AddImage}"
                              Stroke="{DynamicResource secondary_text}"
                              StrokeThickness="1.8"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Margin="-3,-2,0,0"/>
                    </Viewbox>
                </Border>

                <TextBlock Text="Перетащите фото или нажмите для выбора"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           FontSize="15"
                           Foreground="{DynamicResource main_text}"
                           MaxWidth="230"/>

                <TextBlock Text="PNG, JPG до 2 МБ"
                           TextAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource secondary_text}"/>
            </StackPanel>

            <Button x:Name="ClearButton"
                    Classes="Secondary"
                    IsVisible="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Height="28" Width="28"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    CornerRadius="14"
                    Click="OnClearButtonClick"
                    Margin="0,6,6,0"
                    ToolTip.Tip="Удалить изображение">
                <Viewbox Width="10" Height="10" ClipToBounds="False"
                         Margin="-6,-1,0,0">
                    <Path Data="{DynamicResource Сross}"
                          StrokeThickness="2.5"/>
                </Viewbox>
            </Button>

        </Grid>

        <Border x:Name="CompressionWarningText"
                IsVisible="False"
                Background="{DynamicResource elevated}"
                CornerRadius="8"
                Padding="10,7">
            <TextBlock Text="Файл превышает 2 МБ — при сохранении будет сжат до 500 КБ"
                       FontSize="13"
                       Foreground="{DynamicResource warning}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </Border>

    </StackPanel>

</UserControl>
